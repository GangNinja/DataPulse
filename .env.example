# GitHub API settings
GITHUB_TOKEN=ghp_exampleTokenForLocalDevelopment1234567890
GITHUB_OWNER=tensorflow

# Optional: set a repository name for one repo, or leave blank to fetch all owner repos
GITHUB_REPO=

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://datapulse_user:datapulse_password@localhost:5432/datapulse

# Optional request timeout
REQUEST_TIMEOUT_SECONDS=30
